<p style="color: green"></p>

<h1>Users</h1>
<table>
  <thead>
    <tr>
      <th>Role</th>
     <th>Email</th>
      <th colspan="3"></th>
    </tr>
  </thead>
  <tbody>





<div id="users">
  <% @users.each do |user| %>
    <%= render user %>
    <p>
      <%= link_to "Show this user", user %>
    </p>
    <td><%= user.role.name %></td>
<td><%= user.email %></td>
<td><%= link_to 'Show', user %></td>



  <% end %>
</div>



<%= link_to "New user", new_user_path %>

  
  </tbody>
